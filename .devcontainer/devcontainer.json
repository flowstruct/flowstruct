{
  "name": "flowstruct",
  "dockerComposeFile": "compose.yml",
  "service": "dev",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21"
    }
  },
  "postCreateCommand": {
    "api": "cd api && ./mvnw -q -DskipTests dependency:resolve dependency:resolve-plugins",
    "client":  "cd client && pnpm install"
  }
}
