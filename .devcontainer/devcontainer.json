{
  "name": "flowstruct-app",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "postCreateCommand": "pnpm install",
  "workspaceFolder": "/workspace/flowstruct-app",
  "workspaceMount": "source=${localWorkspaceFolder}/flowstruct-app,target=/workspace/flowstruct-app,type=bind,consistency=cached",
  "mounts": [
    "source=flowstruct-app-node-modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
  ]
}