{
  "name": "client",
  "image": "node:22-alpine",
  "workspaceFolder": "/workspace/client",
  "workspaceMount": "source=${localWorkspaceFolder}/client,target=/workspace/client,type=bind,consistency=cached",
  "postCreateCommand": "corepack enable && pnpm install",
  "postStartCommand": "pnpm start:cms --host",
  "appPort": 5173
}
